# Copy to .env on the server. scripts/deploy.sh can generate this file automatically.

# Empty DOMAIN means direct HTTP on :8000. Set a real domain for automatic HTTPS via Caddy.
DOMAIN=craft.example.com
SWL_PUBLIC_URL=https://craft.example.com
SWL_ALLOWED_ORIGINS=https://craft.example.com

# Generate strong values before public launch:
# openssl rand -hex 32
SWL_ADMIN_TOKEN=replace-with-64-random-hex
SWL_PRIVACY_SALT=replace-with-64-random-hex

SWL_ENABLE_HSTS=1
SWL_TRUST_PROXY=1
SWL_MAX_IMAGE_BYTES=5242880

# No-domain mode only. Use a high port on shared servers to avoid existing stacks.
SWL_HTTP_BIND=0.0.0.0
SWL_HTTP_PORT=18080
SWL_RUN_UID=1000
SWL_RUN_GID=1000

# Existing Traefik mode. Use this instead of Caddy when the server already owns 80/443.
# Set SWL_PUBLIC_URL and SWL_ALLOWED_ORIGINS to https://<host>.
SWL_TRAEFIK_HOST=

# Container guardrails.
SWL_APP_MEMORY_LIMIT=512m
SWL_APP_MEMORY_RESERVATION=128m
SWL_APP_CPUS=0.75
SWL_CADDY_MEMORY_LIMIT=128m
SWL_CADDY_MEMORY_RESERVATION=32m
SWL_CADDY_CPUS=0.25
